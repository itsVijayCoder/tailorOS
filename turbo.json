{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@tailoros/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"]
    },
    "@tailoros/api-gateway#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tailoros/control-plane#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tailoros/tenant-api-template#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tailoros/whatsapp-connector#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tailoros/whatsapp-consumer#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "deploy": {
      "dependsOn": ["build", "typecheck"],
      "cache": false
    }
  }
}
